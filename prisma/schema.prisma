generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
  schemas  = ["core", "caracterizacion", "impulsa"]
}

enum EstadoCaracterizacion {
  DRAFT
  COMPLETE
  CONFIRMED

  @@schema("caracterizacion")
}

enum TipoCampo {
  TEXT
  LONG_TEXT
  INTEGER
  DECIMAL
  DATE
  YES_NO_NA
  SECTOR

  @@schema("caracterizacion")
}

enum EstadoRespuesta {
  PENDING
  OK
  NOT_APPLICABLE_AUTO
  MISSING_DETAIL
  INVALID

  @@schema("caracterizacion")
}

enum FuenteAuditoria {
  AUTOSAVE
  MANUAL_SAVE
  IMPORT
  ADMIN_EDIT
  SYSTEM

  @@schema("caracterizacion")
}

enum TipoExportacion {
  GLOBAL
  INDIVIDUAL

  @@schema("caracterizacion")
}

enum EstadoSolicitud {
  DRAFT
  CREATED
  DOCUMENT_GENERATED
  SENT
  CLIENT_OPENED
  CLIENT_SUBMITTED
  UNDER_REVIEW
  COMPLETED
  CANCELLED
  FAILED

  @@schema("impulsa")
}

enum EstadoSolicitudItem {
  PENDING
  SUBMITTED
  UNDER_REVIEW
  ACCEPTED
  REJECTED

  @@schema("impulsa")
}

enum TipoSolicitudItem {
  BASE
  ADVANCED

  @@schema("impulsa")
}

enum TipoSolicitudEvento {
  CREATED
  ITEMS_CREATED
  TOKEN_CREATED
  DOCUMENT_GENERATED
  ONEDRIVE_FOLDERS_CREATED
  EMAIL_SENT
  CLIENT_OPENED
  CLIENT_ITEM_SUBMITTED
  CLIENT_SUBMITTED
  REVIEW_STARTED
  ITEM_ACCEPTED
  ITEM_REJECTED
  COMPLETED
  FAILED
  CANCELLED
  N8N_WEBHOOK_SENT
  N8N_CALLBACK_RECEIVED

  @@schema("impulsa")
}

enum TipoActorSolicitud {
  EMPLEADO
  CLIENTE
  SYSTEM
  N8N

  @@schema("impulsa")
}

enum TipoDocumentoGenerado {
  PDF
  DOCX
  HTML_SNAPSHOT
  JSON_PAYLOAD

  @@schema("impulsa")
}

enum EstadoDocumentoGenerado {
  PENDING
  GENERATED
  STORED
  FAILED

  @@schema("impulsa")
}

model RefEmpresa {
  id                 String   @id @default(uuid()) @db.Uuid
  generalEmpresaId   BigInt?  @unique @map("general_empresa_id")
  razonSocial        String   @map("razon_social") @db.VarChar(255)
  nit                String   @unique @db.VarChar(20)
  digitoVerificacion String?  @map("digito_verificacion") @db.VarChar(1)
  estado             String?  @db.VarChar(15)
  tipoCliente        String?  @map("tipo_cliente") @db.VarChar(30)
  sector             String?  @db.VarChar(150)
  erp                String?  @db.VarChar(150)
  radicadoCode       String?  @unique @map("radicado_code") @db.VarChar(20)
  source             String   @default("manual") @db.VarChar(30)
  isPlaceholder      Boolean  @default(false) @map("is_placeholder")
  createdAt          DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt          DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  asignaciones RefAsignacion[]
  equipos      RefClienteEquipo[]
  planeaciones RefClientePlaneacion[]
  formularios  FormularioCliente[]

  solicitudesImpulsa Solicitud[]
  radicadosImpulsa   Radicado[]

  @@map("ref_empresa")
  @@schema("core")
}

model RefEmpleado {
  id                String   @id @default(uuid()) @db.Uuid
  generalEmpleadoId Int?     @unique @map("general_empleado_id")
  correoCorporativo String   @unique @map("correo_corporativo") @db.VarChar(255)
  nombreCompleto    String   @map("nombre_completo") @db.VarChar(300)
  numeroDocumento   String?  @unique @map("numero_documento") @db.VarChar(30)
  areaId            Int?     @map("area_id")
  areaNombre        String?  @map("area_nombre") @db.VarChar(100)
  cargoId           Int?     @map("cargo_id")
  cargoNombre       String?  @map("cargo_nombre") @db.VarChar(100)
  estado            String?  @db.VarChar(20)
  rolAplicacion     String   @default("senior") @map("rol_aplicacion") @db.VarChar(30)
  source            String   @default("manual") @db.VarChar(30)
  isPlaceholder     Boolean  @default(false) @map("is_placeholder")
  createdAt         DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt         DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  asignaciones           RefAsignacion[]
  equiposComoSocio       RefClienteEquipo[]      @relation("ClienteEquipoSocio")
  equiposComoGerente     RefClienteEquipo[]      @relation("ClienteEquipoGerente")
  equiposComoSenior      RefClienteEquipo[]      @relation("ClienteEquipoSenior")
  equiposComoStaff       RefClienteEquipoStaff[] @relation("ClienteEquipoStaffEmpleado")
  jerarquiasComoEmpleado RefEmpleadoJerarquia[]  @relation("EmpleadoJerarquiaEmpleado")
  jerarquiasComoJefe     RefEmpleadoJerarquia[]  @relation("EmpleadoJerarquiaJefe")
  respuestasAuditadas    RespuestaAudit[]
  exportaciones          ExportLog[]

  solicitudesCreadas     Solicitud[]         @relation("SolicitudCreatedBy")
  solicitudesResponsable Solicitud[]         @relation("SolicitudResponsible")
  eventosSolicitud       SolicitudEvento[]   @relation("SolicitudEventoEmpleado")
  documentosGenerados    DocumentoGenerado[] @relation("DocumentoGeneradoEmpleado")

  adjuntoMatchesConfirmados SolicitudAdjuntoItemMatch[] @relation("AdjuntoItemMatchConfirmedBy")
  itemRevisiones            SolicitudItemRevision[]     @relation("ItemRevisionReviewer")
  revisionesCerradas        SolicitudRevisionCierre[]   @relation("RevisionCierreClosedBy")

  @@map("ref_empleado")
  @@schema("core")
}

model RefAsignacion {
  id                  String  @id @default(uuid()) @db.Uuid
  generalAsignacionId BigInt? @unique @map("general_asignacion_id")

  empresaRefId  String @map("empresa_ref_id") @db.Uuid
  empleadoRefId String @map("empleado_ref_id") @db.Uuid

  empresa  RefEmpresa  @relation(fields: [empresaRefId], references: [id], onDelete: Cascade)
  empleado RefEmpleado @relation(fields: [empleadoRefId], references: [id], onDelete: Cascade)

  generalEmpresaId  BigInt?   @map("general_empresa_id")
  generalEmpleadoId Int?      @map("general_empleado_id")
  areaId            Int?      @map("area_id")
  rol               String    @db.VarChar(25)
  fechaInicio       DateTime? @map("fecha_inicio") @db.Date
  fechaFin          DateTime? @map("fecha_fin") @db.Date
  activo            Boolean   @default(true)
  source            String    @default("manual") @db.VarChar(30)
  createdAt         DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt         DateTime  @updatedAt @map("updated_at") @db.Timestamptz(6)

  @@index([empresaRefId])
  @@index([empleadoRefId])
  @@index([generalEmpresaId])
  @@index([generalEmpleadoId])
  @@map("ref_asignacion")
  @@schema("core")
}

model RefEmpleadoJerarquia {
  id String @id @default(uuid()) @db.Uuid

  empleadoRefId String @map("empleado_ref_id") @db.Uuid
  jefeRefId     String @map("jefe_ref_id") @db.Uuid

  empleado RefEmpleado @relation("EmpleadoJerarquiaEmpleado", fields: [empleadoRefId], references: [id], onDelete: Cascade)
  jefe     RefEmpleado @relation("EmpleadoJerarquiaJefe", fields: [jefeRefId], references: [id], onDelete: Cascade)

  generalEmpleadoId Int?      @map("general_empleado_id")
  generalJefeId     Int?      @map("general_jefe_id")
  tipoRelacion      String    @default("lineal") @map("tipo_relacion") @db.VarChar(30)
  fechaInicio       DateTime? @map("fecha_inicio") @db.Date
  fechaFin          DateTime? @map("fecha_fin") @db.Date
  activo            Boolean   @default(true)
  source            String    @default("manual") @db.VarChar(30)
  createdAt         DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt         DateTime  @updatedAt @map("updated_at") @db.Timestamptz(6)

  @@index([empleadoRefId])
  @@index([jefeRefId])
  @@index([generalEmpleadoId])
  @@index([generalJefeId])
  @@map("ref_empleado_jerarquia")
  @@schema("core")
}

model RefClienteEquipo {
  id String @id @default(uuid()) @db.Uuid

  empresaRefId String     @map("empresa_ref_id") @db.Uuid
  empresa      RefEmpresa @relation(fields: [empresaRefId], references: [id], onDelete: Cascade)

  socioRefId String      @map("socio_ref_id") @db.Uuid
  socio      RefEmpleado @relation("ClienteEquipoSocio", fields: [socioRefId], references: [id], onDelete: Restrict)

  gerenteRefId String      @map("gerente_ref_id") @db.Uuid
  gerente      RefEmpleado @relation("ClienteEquipoGerente", fields: [gerenteRefId], references: [id], onDelete: Restrict)

  seniorRefId String      @map("senior_ref_id") @db.Uuid
  senior      RefEmpleado @relation("ClienteEquipoSenior", fields: [seniorRefId], references: [id], onDelete: Restrict)

  fechaInicio DateTime? @map("fecha_inicio") @db.Date
  fechaFin    DateTime? @map("fecha_fin") @db.Date
  activo      Boolean   @default(true)

  source    String   @default("excel_estructura_jerarquica") @db.VarChar(50)
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  staffs RefClienteEquipoStaff[]

  @@index([empresaRefId])
  @@index([socioRefId])
  @@index([gerenteRefId])
  @@index([seniorRefId])
  @@index([activo])
  @@map("ref_cliente_equipo")
  @@schema("core")
}

model RefClienteEquipoStaff {
  id String @id @default(uuid()) @db.Uuid

  clienteEquipoId String           @map("cliente_equipo_id") @db.Uuid
  clienteEquipo   RefClienteEquipo @relation(fields: [clienteEquipoId], references: [id], onDelete: Cascade)

  staffRefId String      @map("staff_ref_id") @db.Uuid
  staff      RefEmpleado @relation("ClienteEquipoStaffEmpleado", fields: [staffRefId], references: [id], onDelete: Restrict)

  fechaInicio DateTime? @map("fecha_inicio") @db.Date
  fechaFin    DateTime? @map("fecha_fin") @db.Date
  activo      Boolean   @default(true)

  source    String   @default("excel_estructura_jerarquica") @db.VarChar(50)
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  @@index([clienteEquipoId])
  @@index([staffRefId])
  @@index([activo])
  @@map("ref_cliente_equipo_staff")
  @@schema("core")
}

model RefClientePlaneacion {
  id String @id @default(uuid()) @db.Uuid

  empresaRefId String     @map("empresa_ref_id") @db.Uuid
  empresa      RefEmpresa @relation(fields: [empresaRefId], references: [id], onDelete: Cascade)

  year            Int
  nombre          String  @db.VarChar(255)
  descripcion     String?
  requestTypeId   String? @map("request_type_id") @db.VarChar(150)
  requestTypeName String? @map("request_type_name") @db.VarChar(255)

  scheduledDate DateTime? @map("scheduled_date") @db.Date
  dueDate       DateTime? @map("due_date") @db.Date

  estado               String  @default("PLANEADA") @db.VarChar(30)
  generatedSolicitudId String? @map("generated_solicitud_id") @db.Uuid
  activo               Boolean @default(true)

  source    String   @default("manual") @db.VarChar(50)
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  @@index([empresaRefId])
  @@index([year])
  @@index([estado])
  @@index([scheduledDate])
  @@index([generatedSolicitudId])
  @@map("ref_cliente_planeacion")
  @@schema("core")
}

model CampoCaracterizacion {
  id                            String    @id @default(uuid()) @db.Uuid
  code                          String    @unique @db.VarChar(100)
  section                       String    @db.VarChar(100)
  label                         String    @db.VarChar(255)
  helpText                      String?   @map("help_text")
  fieldType                     TipoCampo @map("field_type")
  orderIndex                    Int       @map("order_index")
  isRequired                    Boolean   @default(true) @map("is_required")
  isActive                      Boolean   @default(true) @map("is_active")
  unit                          String?   @db.VarChar(30)
  exportColumnName              String?   @map("export_column_name") @db.VarChar(255)
  dependsOnFieldCode            String?   @map("depends_on_field_code") @db.VarChar(100)
  dependsOnValue                String?   @map("depends_on_value") @db.VarChar(30)
  hasInlineDetail               Boolean   @default(false) @map("has_inline_detail")
  inlineDetailLabel             String?   @map("inline_detail_label") @db.VarChar(255)
  inlineDetailRequiredWhenValue String?   @map("inline_detail_required_when_value") @db.VarChar(30)
  createdAt                     DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt                     DateTime  @updatedAt @map("updated_at") @db.Timestamptz(6)

  respuestas RespuestaCaracterizacion[]

  @@index([orderIndex])
  @@index([section])
  @@index([dependsOnFieldCode])
  @@map("car_campo")
  @@schema("caracterizacion")
}

model FormularioCliente {
  id String @id @default(uuid()) @db.Uuid

  empresaRefId String     @map("empresa_ref_id") @db.Uuid
  empresa      RefEmpresa @relation(fields: [empresaRefId], references: [id], onDelete: Cascade)

  generalEmpresaId     BigInt?               @map("general_empresa_id")
  status               EstadoCaracterizacion @default(DRAFT)
  answeredCount        Int                   @default(0) @map("answered_count")
  totalCount           Int                   @default(38) @map("total_count")
  completionPercentage Decimal               @default(0) @map("completion_percentage") @db.Decimal(5, 2)

  createdByEmpleadoId String? @map("created_by_empleado_id") @db.Uuid
  updatedByEmpleadoId String? @map("updated_by_empleado_id") @db.Uuid

  confirmedAt                DateTime? @map("confirmed_at") @db.Timestamptz(6)
  hasPostConfirmationChanges Boolean   @default(false) @map("has_post_confirmation_changes")

  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  respuestas RespuestaCaracterizacion[]

  @@unique([empresaRefId])
  @@index([generalEmpresaId])
  @@index([status])
  @@map("car_formulario_cliente")
  @@schema("caracterizacion")
}

model RespuestaCaracterizacion {
  id String @id @default(uuid()) @db.Uuid

  formularioId String @map("formulario_id") @db.Uuid
  campoId      String @map("campo_id") @db.Uuid

  formulario FormularioCliente    @relation(fields: [formularioId], references: [id], onDelete: Cascade)
  campo      CampoCaracterizacion @relation(fields: [campoId], references: [id], onDelete: Cascade)

  valueText   String?         @map("value_text")
  valueNumber Decimal?        @map("value_number") @db.Decimal(20, 2)
  valueDate   DateTime?       @map("value_date") @db.Date
  valueJson   Json?           @map("value_json")
  status      EstadoRespuesta @default(PENDING)

  updatedByEmpleadoId String?  @map("updated_by_empleado_id") @db.Uuid
  createdAt           DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt           DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  audits RespuestaAudit[]

  @@unique([formularioId, campoId])
  @@index([formularioId])
  @@index([campoId])
  @@index([status])
  @@map("car_respuesta")
  @@schema("caracterizacion")
}

model RespuestaAudit {
  id String @id @default(uuid()) @db.Uuid

  respuestaId String                   @map("respuesta_id") @db.Uuid
  respuesta   RespuestaCaracterizacion @relation(fields: [respuestaId], references: [id], onDelete: Cascade)

  oldValueJson Json? @map("old_value_json")
  newValueJson Json? @map("new_value_json")

  changedByEmpleadoId String?      @map("changed_by_empleado_id") @db.Uuid
  changedBy           RefEmpleado? @relation(fields: [changedByEmpleadoId], references: [id], onDelete: SetNull)

  source    FuenteAuditoria
  changedAt DateTime        @default(now()) @map("changed_at") @db.Timestamptz(6)

  @@index([respuestaId])
  @@index([changedByEmpleadoId])
  @@index([changedAt])
  @@map("car_respuesta_audit")
  @@schema("caracterizacion")
}

model ExportLog {
  id String @id @default(uuid()) @db.Uuid

  requestedByEmpleadoId String      @map("requested_by_empleado_id") @db.Uuid
  requestedBy           RefEmpleado @relation(fields: [requestedByEmpleadoId], references: [id], onDelete: Restrict)

  exportType     TipoExportacion @map("export_type")
  scope          String          @db.VarChar(50)
  filtersJson    Json?           @map("filters_json")
  columnsJson    Json?           @map("columns_json")
  includedDrafts Boolean         @default(false) @map("included_drafts")
  rowCount       Int             @default(0) @map("row_count")
  fileUrl        String?         @map("file_url")

  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  @@index([requestedByEmpleadoId])
  @@index([exportType])
  @@index([createdAt])
  @@map("car_export_log")
  @@schema("caracterizacion")
}

model RadicadoCounter {
  id              String   @id @default(uuid()) @db.Uuid
  prefix          String   @db.VarChar(20)
  year            Int
  scope           String   @default("global") @db.VarChar(50)
  lastConsecutive Int      @default(0) @map("last_consecutive")
  createdAt       DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt       DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  @@unique([prefix, year, scope])
  @@map("rad_radicado_counter")
  @@schema("impulsa")
}

model Radicado {
  id          String @id @default(uuid()) @db.Uuid
  reference   String @unique @db.VarChar(100)
  prefix      String @db.VarChar(20)
  consecutive Int
  year        Int
  companyCode String @map("company_code") @db.VarChar(80)

  empresaRefId String     @map("empresa_ref_id") @db.Uuid
  empresa      RefEmpresa @relation(fields: [empresaRefId], references: [id], onDelete: Restrict)

  solicitud Solicitud?

  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  // Regla correcta:
  // el consecutivo se reinicia por cliente, año y prefijo.
  @@unique([empresaRefId, prefix, year, consecutive])
  @@index([empresaRefId])
  @@index([year])
  @@index([prefix, year])
  @@map("rad_radicado")
  @@schema("impulsa")
}

model Solicitud {
  id String @id @default(uuid()) @db.Uuid

  radicadoId String   @unique @map("radicado_id") @db.Uuid
  radicado   Radicado @relation(fields: [radicadoId], references: [id], onDelete: Restrict)

  empresaRefId String     @map("empresa_ref_id") @db.Uuid
  empresa      RefEmpresa @relation(fields: [empresaRefId], references: [id], onDelete: Restrict)

  createdByEmpleadoId String?      @map("created_by_empleado_id") @db.Uuid
  createdBy           RefEmpleado? @relation("SolicitudCreatedBy", fields: [createdByEmpleadoId], references: [id], onDelete: SetNull)

  responsibleEmpleadoId String?      @map("responsible_empleado_id") @db.Uuid
  responsible           RefEmpleado? @relation("SolicitudResponsible", fields: [responsibleEmpleadoId], references: [id], onDelete: SetNull)

  requestTypeId   String  @map("request_type_id") @db.VarChar(150)
  requestTypeName String  @map("request_type_name") @db.VarChar(255)
  templateFile    String? @map("template_file") @db.VarChar(255)

  subject        String   @db.VarChar(500)
  cutoffDate     DateTime @map("cutoff_date") @db.Date
  generationDate DateTime @map("generation_date") @db.Date

  clientContactName  String? @map("client_contact_name") @db.VarChar(255)
  clientContactEmail String? @map("client_contact_email") @db.VarChar(255)

  responsibleName String @map("responsible_name") @db.VarChar(255)
  responsibleRole String @map("responsible_role") @db.VarChar(255)
  responsibleFirm String @map("responsible_firm") @db.VarChar(255)

  status EstadoSolicitud @default(CREATED)

  portalUrl String? @map("portal_url")

  // ---------------------------------------------------------------------------
  // OneDrive V2.
  //
  // Estructura definitiva:
  //
  // /{año}/{cliente}/1. Planeación
  // /{año}/{cliente}/2. Ejecución
  // /{año}/{cliente}/3. Cierre
  // /{año}/{cliente}/4. Impuestos
  // /{año}/{cliente}/5. Comunicaciones/{radicado}/{categoría}/archivo
  //
  // Regla:
  // - una carpeta de cliente por año;
  // - no una carpeta de cliente por solicitud;
  // - cada solicitud vive dentro de "5. Comunicaciones";
  // - cada categoría de la solicitud tiene su propia carpeta.
  // ---------------------------------------------------------------------------

  oneDriveYearFolderUrl String? @map("onedrive_year_folder_url")
  oneDriveYearFolderId  String? @map("onedrive_year_folder_id") @db.VarChar(255)

  oneDriveClientFolderUrl String? @map("onedrive_client_folder_url")
  oneDriveClientFolderId  String? @map("onedrive_client_folder_id") @db.VarChar(255)

  oneDrivePlaneacionFolderUrl String? @map("onedrive_planeacion_folder_url")
  oneDrivePlaneacionFolderId  String? @map("onedrive_planeacion_folder_id") @db.VarChar(255)

  oneDriveEjecucionFolderUrl String? @map("onedrive_ejecucion_folder_url")
  oneDriveEjecucionFolderId  String? @map("onedrive_ejecucion_folder_id") @db.VarChar(255)

  oneDriveCierreFolderUrl String? @map("onedrive_cierre_folder_url")
  oneDriveCierreFolderId  String? @map("onedrive_cierre_folder_id") @db.VarChar(255)

  oneDriveImpuestosFolderUrl String? @map("onedrive_impuestos_folder_url")
  oneDriveImpuestosFolderId  String? @map("onedrive_impuestos_folder_id") @db.VarChar(255)

  oneDriveComunicacionesFolderUrl String? @map("onedrive_comunicaciones_folder_url")
  oneDriveComunicacionesFolderId  String? @map("onedrive_comunicaciones_folder_id") @db.VarChar(255)

  oneDriveControlInternoFolderUrl String? @map("onedrive_control_interno_folder_url")
  oneDriveControlInternoFolderId  String? @map("onedrive_control_interno_folder_id") @db.VarChar(255)

  oneDriveSolicitudesInformacionFolderUrl String? @map("onedrive_solicitudes_informacion_folder_url")
  oneDriveSolicitudesInformacionFolderId  String? @map("onedrive_solicitudes_informacion_folder_id") @db.VarChar(255)

  // Legacy. Conservado temporalmente para migración/lectura histórica.
  // La estructura nueva no crea 5. Comunicaciones/{radicado}.
  oneDriveSolicitudComunicacionFolderUrl String? @map("onedrive_solicitud_comunicacion_folder_url")
  oneDriveSolicitudComunicacionFolderId  String? @map("onedrive_solicitud_comunicacion_folder_id") @db.VarChar(255)

  n8nExecutionId    String?   @map("n8n_execution_id") @db.VarChar(255)
  n8nLastWebhookAt  DateTime? @map("n8n_last_webhook_at") @db.Timestamptz(6)
  n8nLastCallbackAt DateTime? @map("n8n_last_callback_at") @db.Timestamptz(6)
